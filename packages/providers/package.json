{
  "name": "@ax/providers",
  "version": "11.0.0-alpha.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "description": "Provider implementations for AutomatosX",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./claude": {
      "types": "./dist/claude.d.ts",
      "import": "./dist/claude.js"
    },
    "./gemini": {
      "types": "./dist/gemini.d.ts",
      "import": "./dist/gemini.js"
    },
    "./ax-cli": {
      "types": "./dist/ax-cli.d.ts",
      "import": "./dist/ax-cli.js"
    },
    "./openai": {
      "types": "./dist/openai.d.ts",
      "import": "./dist/openai.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ax/schemas": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.22.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
