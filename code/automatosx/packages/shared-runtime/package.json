{
  "name": "@defai.digital/shared-runtime",
  "version": "14.0.1",
  "description": "Shared workflow runtime service used by CLI and MCP surfaces",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "workflows",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/runtime-public-bridge-exports.d.ts",
      "import": "./dist/runtime-public-bridge-exports.js"
    },
    "./governance": {
      "types": "./dist/runtime-public-governance-exports.d.ts",
      "import": "./dist/runtime-public-governance-exports.js"
    },
    "./catalog": {
      "types": "./dist/runtime-public-catalog-exports.d.ts",
      "import": "./dist/runtime-public-catalog-exports.js"
    }
  },
  "dependencies": {
    "@defai.digital/contracts": "^14.0.1",
    "@defai.digital/state-store": "^14.0.1",
    "@defai.digital/trace-store": "^14.0.1",
    "@defai.digital/workflow-engine": "^14.0.1",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  }
}
