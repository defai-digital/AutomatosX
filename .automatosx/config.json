{
  "$schema": "https://raw.githubusercontent.com/defai-digital/automatosx/main/schemas/config.schema.json",
  "version": "11.0.0-alpha.0",
  "mcpServers": {
    "automatosx": {
      "command": "node",
      "args": ["./packages/mcp/dist/server.js"],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "production",
        "AUTOMATOSX_BASE_PATH": "${workspaceFolder}/.automatosx"
      },
      "description": "AutomatosX Agent Orchestration Platform",
      "timeout": 300000,
      "capabilities": {
        "tools": true,
        "resources": false,
        "prompts": false
      }
    }
  },
  "defaults": {
    "provider": "claude",
    "timeout": 300000,
    "maxRetries": 3
  },
  "memory": {
    "enabled": true,
    "maxEntries": 10000,
    "dbPath": ".automatosx/memory/memories.db"
  },
  "sessions": {
    "storagePath": ".automatosx/sessions",
    "autoPersist": true
  },
  "agents": {
    "basePath": ".automatosx/agents",
    "defaultAgent": "standard"
  }
}
