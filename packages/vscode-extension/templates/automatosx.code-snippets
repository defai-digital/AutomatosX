{
  "AX Agent YAML": {
    "scope": "yaml",
    "prefix": "ax-agent",
    "body": [
      "# ${1:Agent Name}",
      "# ${2:Brief description of the agent}",
      "",
      "name: ${3:agent-id}",
      "displayName: \"${1:Agent Name}\"",
      "role: \"${4:Role description}\"",
      "team: ${5|engineering,research,creative,executive,default|}",
      "description: |",
      "  ${2:Brief description of the agent}",
      "",
      "abilities:",
      "  - ${6:ability-1}",
      "  - ${7:ability-2}",
      "",
      "abilitySelection:",
      "  core:",
      "    - ${6:ability-1}",
      "  taskBased:",
      "    ${8:keyword}:",
      "      - ${9:related-ability}",
      "",
      "personality:",
      "  traits:",
      "    - ${10:helpful}",
      "    - ${11:thorough}",
      "  communicationStyle: ${12|technical,formal,casual,friendly|}",
      "  decisionMaking: ${13|analytical,data-driven,intuitive,collaborative|}",
      "",
      "orchestration:",
      "  maxDelegationDepth: ${14:2}",
      "  canWriteToShared: true",
      "  canDelegateTo:",
      "    - ${15:other-agent}",
      "  priority: ${16:5}",
      "",
      "systemPrompt: |",
      "  You are ${1:Agent Name}, a specialized AI agent.",
      "  ",
      "  Your role: ${4:Role description}",
      "  ",
      "  Your capabilities:",
      "  - ${17:Capability 1}",
      "  - ${18:Capability 2}",
      "  ",
      "  When handling tasks:",
      "  1. ${19:First step}",
      "  2. ${20:Second step}",
      "  3. ${21:Third step}",
      "",
      "enabled: true",
      "version: \"1.0.0\""
    ],
    "description": "Create a new AutomatosX agent profile"
  },
  "AX Agent Minimal": {
    "scope": "yaml",
    "prefix": "ax-agent-minimal",
    "body": [
      "name: ${1:agent-id}",
      "displayName: \"${2:Agent Name}\"",
      "role: \"${3:Role description}\"",
      "team: ${4|engineering,research,creative,default|}",
      "enabled: true",
      "",
      "abilities:",
      "  - ${5:ability}",
      "",
      "systemPrompt: |",
      "  You are ${2:Agent Name}.",
      "  ${6:Your instructions here}"
    ],
    "description": "Create a minimal AutomatosX agent profile"
  },
  "AX Config": {
    "scope": "json,jsonc",
    "prefix": "ax-config",
    "body": [
      "{",
      "  \"\\$schema\": \"https://automatosx.dev/schema/config.json\",",
      "  \"version\": \"11.0.0\",",
      "  \"providers\": {",
      "    \"default\": \"${1|ax-cli,claude,gemini,openai|}\",",
      "    \"fallbackOrder\": [\"ax-cli\", \"claude\", \"gemini\"]",
      "  },",
      "  \"router\": {",
      "    \"healthCheckInterval\": 30000,",
      "    \"preferMcp\": true,",
      "    \"routingStrategy\": \"${2|capability-first,round-robin,least-latency|}\"",
      "  },",
      "  \"execution\": {",
      "    \"timeout\": ${3:300000},",
      "    \"retry\": {",
      "      \"maxAttempts\": 3,",
      "      \"initialDelay\": 1000,",
      "      \"maxDelay\": 10000,",
      "      \"backoffMultiplier\": 2",
      "    },",
      "    \"streaming\": true",
      "  },",
      "  \"memory\": {",
      "    \"maxEntries\": ${4:10000},",
      "    \"autoCleanup\": true,",
      "    \"cleanupStrategy\": \"${5|lru,time-based,hybrid|}\",",
      "    \"retentionDays\": ${6:90}",
      "  },",
      "  \"agents\": {",
      "    \"defaultAgent\": \"${7:standard}\",",
      "    \"maxDelegationDepth\": ${8:3},",
      "    \"enableAutoSelection\": true",
      "  }",
      "}"
    ],
    "description": "Create AutomatosX configuration file"
  },
  "AX MCP Server Config": {
    "scope": "json,jsonc",
    "prefix": "ax-mcp-config",
    "body": [
      "{",
      "  \"mcpServers\": {",
      "    \"automatosx\": {",
      "      \"command\": \"npx\",",
      "      \"args\": [\"ax-mcp\"],",
      "      \"env\": {",
      "        \"AUTOMATOSX_BASE_PATH\": \"\\${workspaceFolder}/.automatosx\"",
      "      }",
      "    }",
      "  }",
      "}"
    ],
    "description": "MCP server configuration for Claude Code"
  },
  "AX Ability": {
    "scope": "yaml",
    "prefix": "ax-ability",
    "body": [
      "# ${1:Ability Name}",
      "# ${2:What this ability enables}",
      "",
      "name: ${3:ability-id}",
      "displayName: \"${1:Ability Name}\"",
      "description: |",
      "  ${2:What this ability enables}",
      "",
      "# Keywords that trigger this ability",
      "keywords:",
      "  - ${4:keyword1}",
      "  - ${5:keyword2}",
      "",
      "# System prompt additions when this ability is active",
      "promptAdditions: |",
      "  ${6:Additional instructions for this ability}"
    ],
    "description": "Create an AutomatosX ability definition"
  }
}
