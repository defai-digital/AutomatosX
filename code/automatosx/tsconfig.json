{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@defai.digital/contracts": [
        "./packages/contracts/src/index.ts"
      ],
      "@defai.digital/mcp-server": [
        "./packages/mcp-server/src/index.ts"
      ],
      "@defai.digital/monitoring": [
        "./packages/monitoring/src/index.ts"
      ],
      "@defai.digital/shared-runtime": [
        "./packages/shared-runtime/src/index.ts"
      ],
      "@defai.digital/shared-runtime/bridge": [
        "./packages/shared-runtime/src/runtime-public-bridge-exports.ts"
      ],
      "@defai.digital/shared-runtime/governance": [
        "./packages/shared-runtime/src/runtime-public-governance-exports.ts"
      ],
      "@defai.digital/shared-runtime/catalog": [
        "./packages/shared-runtime/src/runtime-public-catalog-exports.ts"
      ],
      "@defai.digital/state-store": [
        "./packages/state-store/src/index.ts"
      ],
      "@defai.digital/trace-store": [
        "./packages/trace-store/src/index.ts"
      ],
      "@defai.digital/workflow-engine": [
        "./packages/workflow-engine/src/index.ts"
      ]
    },
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "packages/**/*.ts",
    "tests/**/*.ts",
    "tools/**/*.ts",
    "vitest.config.ts"
  ]
}
