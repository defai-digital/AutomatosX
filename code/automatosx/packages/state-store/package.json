{
  "name": "@defai.digital/state-store",
  "version": "14.0.2",
  "description": "Shared memory and policy store for CLI and MCP workflow execution",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  }
}
